def check_goal_completion(goal: str, snapshot: str) -> dict:
    content_snippet = snapshot[:8000]
    response = client.chat.completions.create(
        model=NIM_MODEL,
        messages=[
            {"role": "system", "content": GOAL_CHECK_PROMPT.format(goal=goal, snapshot=content_snippet)},
            {"role": "user", "content": f"Goal: {goal}\n\nPage Content:\n{content_snippet}"},
        ],
        max_tokens=100,
        temperature=0,
    )
    raw = response.choices[0].message.content.strip()
    raw = re.sub(r"^```json\s*|\s*```$", "", raw.strip())
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {"success": False, "reason": "Failed to parse LLM response"}
def execute_action(mcp: MCPClient, plan: dict, snapshot: str, extracted: dict) -> bool:
    """Executes a single planned action. Returns True if the loop should stop."""
    action = plan.get("action")
    if action == "navigate":
        url = plan.get("url")
        if not url:
            print("  [Error] navigate requires a url.")
            return False
        mcp.call_tool("browser_navigate", {"url": url})
        mcp.call_tool("browser_wait_for", {"time": 3})
        return False
    if action == "click":
        ref = plan.get("ref")
        if not ref:
            print("  [Error] click requires a ref.")
            return False
        mcp.call_tool("browser_click", {"element": "target", "ref": ref})
        mcp.call_tool("browser_wait_for", {"time": 1})
        return False
    if action == "type":
        ref = plan.get("ref")
        text = plan.get("text", "")
        if not ref:
            print("  [Error] type requires a ref.")
            return False
        mcp.call_tool("browser_type", {"element": "target", "ref": ref, "text": text})
        mcp.call_tool("browser_wait_for", {"time": 1})
        return False
    if action == "wait":
        seconds = plan.get("time", 2)
        mcp.call_tool("browser_wait_for", {"time": seconds})
        return False
    if action == "scroll":
        direction = plan.get("direction", "down")
        amount = plan.get("amount", 500)
        delta = amount if direction == "down" else -amount
        # browser_scroll tool, if exposed by the MCP server, takes a pixel delta.
        mcp.call_tool("browser_scroll", {"direction": direction, "amount": amount})
        mcp.call_tool("browser_wait_for", {"time": 1})
        return False
    if action == "extract_text": # copy and saves the whole text 
        text = extract_readable_text(snapshot)
        extracted.setdefault("text", []).append(text)
        print(f"  [Extracted text] {len(text)} chars captured.")
        return False
    if action == "extract_files": # just saves the name and ref point of the file 
        files = extract_file_links(snapshot)
        extracted.setdefault("files", []).extend(files)
        print(f"  [Extracted files] {len(files)} file(s) found: "
              f"{[f['name'] for f in files]}")
        return False
    if action == "finish":
        print(f"  [Agent decided]: Finish. Success: {plan.get('success')}")
        return True
    print(f"  [Error] Unknown action: {action}")
    return True
def run_agent(goal: str, start_url: str):
    mcp = MCPClient()
    mcp.start()
    mcp.list_tools()
    print(f"\nGoal : {goal}")
    print(f"URL  : {start_url}")
    print("=" * 60)
    extracted_data: dict = {}
    last_action_signature = ""
    wait_time = random.uniform(1.5, 4.0)
    mcp.call_tool("browser_navigate", {"url": start_url})
    mcp.call_tool("browser_wait_for", {"time": wait_time})
    for step in range(1, MAX_NAV_STEPS + 1):
        print(f"\n--- Step {step}: Planning ---")
        snapshot = mcp.call_tool("browser_snapshot", {})
        if not snapshot or snapshot == "Snapshot empty.":
            snapshot = find_and_read_latest_snapshot()
        if not snapshot:
            print("STUCK: Could not get snapshot.")
            break
        status = check_goal_completion(goal, snapshot)
        print(f"  [LLM Status]: Success={status.get('success')} | Reason: {status.get('reason', 'Unknown')}")
        is_success = status.get("success", False)
        if is_success:
            reason_lower = status.get("reason", "").lower()
            if "link" in reason_lower and not any(
                w in reason_lower for w in ["heading", "list", "content", "feed", "video"]
            ):
                print("  [SAFETY OVERRIDE] LLM confused a sidebar link with the destination page. Ignoring success.")
                is_success = False
        if is_success:
            print(f"\n{'='*60}\nGOAL ACHIEVED: {status['reason']}\n{'='*60}")
            break
        plan = plan_navigation_step(goal, snapshot)
        action = plan.get("action")
        current_sig = (
            f"{action}_{plan.get('ref','')}_{plan.get('url','')}_"
            f"{plan.get('text','')}_{plan.get('direction','')}"
        )
        if current_sig == last_action_signature:
            print("  [LOOP DETECTED] Agent is repeating the same action. Stopping.")
            break
        last_action_signature = current_sig
        print(f"  [Plan]: {action} - {plan.get('reason', '')}")
        should_stop = execute_action(mcp, plan, snapshot, extracted_data)
        if should_stop:
            break
    else:
        print("\nMax steps reached. Goal may not be achieved.")
    if extracted_data.get("text"):
        print("\n--- Extracted Text ---")
        print("\n---\n".join(extracted_data["text"])[:3000])
    if extracted_data.get("files"):
        print("\n--- Extracted Files ---")
        for f in extracted_data["files"]:
            print(f"  {f['name']}  (ref={f['ref']})")
    mcp.stop()
if __name__ == "__main__":
    goal = input("Enter your goal : ").strip()
    start_url = input("Starting URL    : ").strip()
    run_agent(goal, start_url)