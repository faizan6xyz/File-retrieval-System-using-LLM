def plan_navigation_step(goal: str, snapshot: str) -> dict:
    try:
        response = client.chat.completions.create(
            model=NIM_MODEL,
            messages=[
                {"role": "system", "content": NAV_PLANNER_PROMPT.format(goal=goal)},
                {"role": "user", "content": snapshot[:15000]},
            ],
            max_tokens=200,
            temperature=0,
        )
        raw = response.choices[0].message.content.strip()
        raw = re.sub(r"^```json\s*|\s*```$", "", raw.strip())
        return json.loads(raw)
    except Exception as e:
        print(f"    [ERROR] Planning failed: {e}")
        return {"action": "finish", "success": False, "reason": f"planner error: {e}"}
GOAL_CHECK_PROMPT = """You are an intelligent verification agent.
Your task is to determine if the user has ACTUALLY ARRIVED at the destination/state they requested.

User Goal: "{goal}"
Current Page Snapshot:
{snapshot}

CRITICAL VERIFICATION RULES:

1. SIDEBAR vs. MAIN CONTENT:
